{
  "name": "VillaOwner",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "whatsapp": {
      "type": "string"
    },
    "nationality": {
      "type": "string"
    },
    "villa_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract_start": {
      "type": "string",
      "format": "date"
    },
    "contract_end": {
      "type": "string",
      "format": "date"
    },
    "revenue_share_percent": {
      "type": "number"
    },
    "management_fee_type": {
      "type": "string",
      "enum": [
        "percentage",
        "fixed"
      ],
      "default": "percentage"
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "prospect"
      ],
      "default": "active"
    }
  },